          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les fichiers hors ligne les plus volumineux. Idéal pour un zoom important et les grands écrans."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "オフラインファイルは最大になります。大きく拡大する場合や大画面に最適です。"

    "Real-time updates allow the app to automatically refresh when content changes on the server." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Echtzeit-Updates ermöglichen es der App, sich automatisch zu aktualisieren, wenn sich Inhalte auf dem Server ändern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Real-time updates allow the app to automatically refresh when content changes on the server."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les mises à jour en temps réel permettent à l'app de se rafraîchir automatiquement quand le contenu du serveur change."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "リアルタイム更新によりサーバー変更時にアプリが自動で更新されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "실시간 업데이트를 사용하면 서버에서 콘텐츠가 변경될 때 앱이 자동으로 새로고침됩니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "开启后服务器变更会自动刷新。"

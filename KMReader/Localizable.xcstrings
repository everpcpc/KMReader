    "PDF books open with DIVINA Reader. Recommended for comic and manga PDFs, especially when offline-downloaded pages are rendered as images." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PDF-Bücher werden mit dem DIVINA-Reader geöffnet. Empfohlen für Comic- und Manga-PDFs, besonders wenn offline heruntergeladene Seiten als Bilder gerendert werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PDF books open with DIVINA Reader. Recommended for comic and manga PDFs, especially when offline-downloaded pages are rendered as images."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les livres PDF s'ouvrent avec le lecteur DIVINA. Recommandé pour les PDF de bandes dessinées et de mangas, surtout lorsque les pages téléchargées hors ligne sont rendues sous forme d'images."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PDF書籍はDIVINA Readerで開きます。特にオフラインでダウンロードしたページを画像としてレンダリングする場合、コミックやマンガのPDFに適しています。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PDF 책은 DIVINA Reader로 열립니다. 특히 오프라인 다운로드 페이지를 이미지로 렌더링하는 경우 만화와 망가 PDF에 권장됩니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PDF 书籍会使用 DIVINA Reader 打开，推荐用于 PDF 漫画，尤其适合将离线下载页面渲染为图片的场景。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PDF 書籍會使用 DIVINA Reader 開啟，推薦用於 PDF 漫畫，尤其適合將離線下載頁面渲染為圖片的場景。"
          }
        }
      }
    },

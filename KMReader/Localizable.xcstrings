    "To find font names, go to Settings > General > Fonts on your device. All fonts, including profile-installed fonts, are available." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Um Schriftartnamen zu finden, gehen Sie auf Ihrem Gerät zu Einstellungen > Allgemein > Schriftarten. Alle Schriftarten, einschließlich durch Profile installierte, sind verfügbar."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To find font names, go to Settings > General > Fonts on your device. All fonts, including profile-installed fonts, are available."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pour trouver les noms des polices, allez dans Réglages > Général > Polices sur votre appareil. Toutes les polices, y compris celles installées via profil, sont disponibles."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "フォント名は「設定 > 一般 > フォント」で確認できます。プロファイル経由のフォントも利用可能です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "글꼴 이름을 찾으려면 기기에서 설정 > 일반 > 글꼴로 이동하세요. 프로필 설치 글꼴을 포함한 모든 글꼴을 사용할 수 있습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "要查看字体名称，请在设备“设置 > 通用 > 字体”，包含个人安装字体。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "要查看字體名稱，請到裝置「設定 > 一般 > 字體」，含個人安裝字體。"
          }
        }
      }
    },

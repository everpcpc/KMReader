    "Improve clarity for low-resolution pages using built-in waifu2x (2x)." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verbessert die Klarheit von Bildern mit niedriger Auflösung mit integriertem waifu2x (2x)."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Improve clarity for low-resolution pages using built-in waifu2x (2x)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Améliore la netteté des images basse résolution grâce à waifu2x intégré (2x)."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "内蔵の waifu2x（2x）で低解像度ページの鮮明さを向上します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "내장 waifu2x(2x)를 사용해 저해상도 페이지의 선명도를 높입니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {

    "Credentials are stored locally so you can switch servers without re-entering them." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anmeldeinformationen werden lokal gespeichert, sodass Sie zwischen Servern wechseln können, ohne sie erneut eingeben zu müssen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Credentials are stored locally so you can switch servers without re-entering them."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les identifiants sont stockés localement pour pouvoir changer de serveur sans les ressaisir."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "認証情報はローカルに保存され、サーバー切替時の再入力は不要です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "자격 증명은 로컬에 저장되므로 다시 입력하지 않고도 서버를 전환할 수 있습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",

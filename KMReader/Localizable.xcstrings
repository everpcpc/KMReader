    "settings.appearance.appIcon.simulatorIssue" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das Wechseln des App-Symbols ist im iOS-26.1+-Simulator derzeit nicht verfügbar. Bitte auf einem echten Gerät oder einer älteren Simulator-Runtime testen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "App icon switching is currently unavailable on iOS 26.1+ Simulator. Please test on a real device or an older simulator runtime."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le changement d’icône de l’app n’est actuellement pas disponible sur le simulateur iOS 26.1+. Veuillez tester sur un appareil réel ou une ancienne runtime de simulateur."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS 26.1 以降のシミュレータでは現在、アプリアイコンの切り替えは利用できません。実機または古いシミュレータランタイムで確認してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS 26.1 이상 시뮬레이터에서는 현재 앱 아이콘 변경을 사용할 수 없습니다. 실제 기기 또는 더 낮은 시뮬레이터 런타임에서 테스트해 주세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS 26.1 及以上模拟器当前无法切换应用图标。请在真机或更低版本的模拟器运行时测试。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS 26.1 及以上模擬器目前無法切換 App 圖示。請在實機或較低版本的模擬器執行環境測試。"
          }
        }
      }
    },

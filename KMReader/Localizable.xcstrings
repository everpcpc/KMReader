    "This will permanently delete %@ from Komga." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dies wird %@ dauerhaft aus Komga löschen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will permanently delete %@ from Komga."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ceci supprimera définitivement %@ de Komga."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ を Komga から完全に削除します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이렇게 하면 Komga에서 %@이(가) 영구적으로 삭제됩니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这将从 Komga 永久删除 %@。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "這將從 Komga 永久刪除 %@。"
          }
        }
      }
    },
    "This will remove %@, its credentials, and all cached data for this server." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dies entfernt %@, dessen Anmeldedaten und alle zwischengespeicherten Daten für diesen Server."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will remove %@, its credentials, and all cached data for this server."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela supprimera %@, ses identifiants et toutes les données mises en cache pour ce serveur."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ とその認証情報、キャッシュ済みデータをすべて削除します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이렇게 하면 %@, 자격 증명 및 이 서버의 모든 캐시된 데이터가 제거됩니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将移除 %@、其凭证和所有缓存数据。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "將移除 %@、其憑證與所有快取資料。"
          }
        }
      }
    },
    "This will remove all cached covers for all servers. Covers will be re-downloaded when needed." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dies entfernt alle zwischengespeicherten Cover für alle Server. Cover werden bei Bedarf erneut heruntergeladen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will remove all cached covers for all servers. Covers will be re-downloaded when needed."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela supprimera toutes les couvertures en cache de tous les serveurs. Les couvertures seront retéléchargées si nécessaire."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "全サーバーのカバーキャッシュをすべて削除します。必要に応じ再ダウンロードされます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "모든 서버에서 캐시된 모든 커버가 제거됩니다. 필요할 때 커버가 다시 다운로드됩니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将移除所有服务器的缓存封面，需时会重新下载。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "將移除所有伺服器的快取封面，需要時會重新下載。"
          }
        }
      }
    },
    "This will remove all cached page images for all servers. Images will be re-downloaded when needed." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dadurch werden alle zwischengespeicherten Seitenbilder für alle Server entfernt. Bilder werden bei Bedarf erneut heruntergeladen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will remove all cached page images for all servers. Images will be re-downloaded when needed."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela supprimera toutes les images de page mises en cache pour tous les serveurs. Les images seront de nouveau téléchargées si nécessaire."
          }
        },

    "offline.sync.confirm.message" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dadurch werden Bibliotheken, Serien und Bücher für die Offline-Nutzung aktualisiert. Bei großen Bibliotheken kann die Synchronisierung länger dauern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This will refresh libraries, series, and books for offline browsing. Large libraries may take longer to sync."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela actualisera les bibliothèques, séries et livres pour la navigation hors ligne. La synchronisation peut prendre plus de temps pour les grandes bibliothèques."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "オフライン閲覧のためにライブラリ、シリーズ、書籍を更新します。ライブラリが大きい場合、同期に時間がかかることがあります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "오프라인 탐색을 위해 라이브러리, 시리즈, 도서를 새로 고칩니다. 라이브러리가 큰 경우 동기화에 시간이 더 걸릴 수 있습니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将刷新用于离线浏览的库、系列和书籍数据。库较大时同步可能需要更长时间。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "將刷新用於離線瀏覽的資料庫、系列和書籍資料。大型資料庫同步可能需要較長時間。"
          }
        }
      }
    },

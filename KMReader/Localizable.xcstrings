    "Auto scale only when required scale to fit the page on screen is greater than this value." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Automatisch nur hochskalieren, wenn der zum Einpassen der Seite auf dem Bildschirm erforderliche Skalierungsfaktor größer als dieser Wert ist."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Auto scale only when required scale to fit the page on screen is greater than this value."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Effectuer une mise à l'échelle automatique uniquement lorsque le facteur requis pour adapter la page à l'écran est supérieur à cette valeur."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ページを画面内に収めるために必要な拡大率がこの値より大きい場合のみ自動で拡大します。"

    "The quick brown fox jumps over the lazy dog. This is a sample text to preview your reading preferences." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der schnelle braune Fuchs springt über den faulen Hund. Dies ist ein Beispieltext zur Vorschau Ihrer Leseeinstellungen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The quick brown fox jumps over the lazy dog. This is a sample text to preview your reading preferences."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le rapide renard brun saute par-dessus le chien paresseux. Ceci est un exemple de texte pour prévisualiser vos préférences de lecture."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "素早い茶色のキツネが怠け者の犬を飛び越えます。これは読書設定をプレビューするためのサンプルテキストです。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "빠른 갈색 여우가 게으른 개를 뛰어넘습니다. 이것은 읽기 설정을 미리 보기 위한 샘플 텍스트입니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "快速的棕色狐狸跳过懒狗。这是一段示例文本，用于预览您的阅读偏好设置。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "快速的棕色狐狸跳過懶狗。這是一段示例文本，用於預覽您的閱讀偏好設定。"
          }
        }
      }
    },

    "Adjust the maximum size of the cover cache. Cache will be cleaned automatically when exceeded." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Passen Sie die maximale Größe des Cover-Caches an. Der Cache wird automatisch geleert, wenn er überschritten wird."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adjust the maximum size of the cover cache. Cache will be cleaned automatically when exceeded."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajustez la taille maximale du cache des couvertures. Le cache sera nettoyé automatiquement en cas de dépassement."
          }

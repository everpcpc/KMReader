    "NSFaceIDUsageDescription" : {
      "comment" : "Privacy - Face ID Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Face ID zum Entsperren geschützter Komga-Server verwenden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Use Face ID to unlock protected Komga servers."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Usar Face ID para desbloquear servidores Komga protegidos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utiliser Face ID pour déverrouiller les serveurs Komga protégés."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Usa Face ID per sbloccare i server Komga protetti."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Face IDを使用して保護されたKomgaサーバーのロックを解除します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Face ID를 사용하여 보호된 Komga 서버의 잠금을 해제합니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Используйте Face ID для разблокировки защищенных серверов Komga."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用面容 ID 解锁受保护的 Komga 服务器。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用 Face ID 解鎖受保護的 Komga 伺服器。"
          }
        }
      }
    },
